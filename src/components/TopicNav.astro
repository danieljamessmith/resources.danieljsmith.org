---
export interface TopicItem {
  id: string;
  label: string;
}

export type TopicNavAccent = 'purple' | 'teal';

interface Props {
  variant?: 'sidebar' | 'mobile';
  topics: TopicItem[];
  accent?: TopicNavAccent;
}

const { variant = 'sidebar', topics, accent = 'purple' } = Astro.props;

const linkInactive =
  'block border-l-2 border-transparent pl-4 py-2 text-sm text-slate-400 hover:border-slate-400 hover:text-white transition-colors duration-150';
// Accent-aware hover colour for the mobile chip row; explicit branches so Tailwind JIT keeps both sets.
const mobileInactive =
  accent === 'teal'
    ? 'flex-shrink-0 whitespace-nowrap rounded-full border border-slate-600/80 px-3 py-1.5 text-xs font-medium text-slate-300 transition-colors hover:border-teal-500/50 hover:text-white'
    : 'flex-shrink-0 whitespace-nowrap rounded-full border border-slate-600/80 px-3 py-1.5 text-xs font-medium text-slate-300 transition-colors hover:border-purple-500/50 hover:text-white';
const enableLiveTopicHighlight = true;
---

{
  variant === 'sidebar' ? (
    <nav
      class="topic-nav-sidebar hidden w-52 shrink-0 lg:block"
      aria-label="Topic navigation"
      data-topic-nav="sidebar"
      data-topic-accent={accent}
    >
      <p class="mb-4 text-xs font-semibold uppercase tracking-widest text-slate-400">Topic</p>
      <ul class="space-y-1 pr-4" role="list">
        {topics.map((t) => (
          <li>
            <a
              href={`#${t.id}`}
              class={linkInactive}
              data-topic-target={t.id}
              data-topic-link="sidebar"
            >
              {t.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  ) : (
    <nav
      class="topic-nav-mobile -mx-1 mb-6 flex gap-2 overflow-x-auto pb-1 pt-1 lg:hidden"
      aria-label="Topic navigation"
      data-topic-nav="mobile"
      data-topic-accent={accent}
    >
      {topics.map((t) => (
        <a
          href={`#${t.id}`}
          class={mobileInactive}
          data-topic-target={t.id}
          data-topic-link="mobile"
        >
          {t.label}
        </a>
      ))}
    </nav>
  )
}

{variant === 'sidebar' && enableLiveTopicHighlight && (
<script>
  function setupFurtherMathsTopicNav() {
    const main = document.querySelector('main');
    if (!main) return;

    const headings = [...main.querySelectorAll('h2[id]')] as HTMLElement[];
    if (headings.length === 0) return;

    const sidebarLinks = document.querySelectorAll<HTMLAnchorElement>('[data-topic-link="sidebar"]');
    const mobileLinks = document.querySelectorAll<HTMLAnchorElement>('[data-topic-link="mobile"]');

    // Read accent from the rendered nav so the active classes match the strand colour.
    // Explicit class strings below (not template-built) so Tailwind JIT keeps them.
    const sidebarNav = document.querySelector<HTMLElement>('[data-topic-nav="sidebar"]');
    const accent = sidebarNav?.dataset.topicAccent === 'teal' ? 'teal' : 'purple';
    const activeBorderClass = accent === 'teal' ? 'border-teal-500' : 'border-purple-500';
    const activeChipBgClass = accent === 'teal' ? 'bg-teal-500/15' : 'bg-purple-500/15';

    const focusLineY = 96;
    const hashLockMs = 900;
    const validTopicIds = new Set(headings.map((h) => h.id));
    let hashLockUntil = 0;

    function setActive(id: string) {
      sidebarLinks.forEach((a) => {
        const isActive = a.dataset.topicTarget === id;
        a.classList.toggle('text-white', isActive);
        a.classList.toggle('font-medium', isActive);
        a.classList.toggle(activeBorderClass, isActive);
        a.classList.toggle('text-slate-400', !isActive);
        a.classList.toggle('border-transparent', !isActive);
        if (isActive) a.setAttribute('aria-current', 'location');
        else a.removeAttribute('aria-current');
      });
      mobileLinks.forEach((a) => {
        const isActive = a.dataset.topicTarget === id;
        a.classList.toggle(activeBorderClass, isActive);
        a.classList.toggle(activeChipBgClass, isActive);
        a.classList.toggle('text-white', isActive);
        a.classList.toggle('border-slate-600/80', !isActive);
        a.classList.toggle('text-slate-300', !isActive);
        if (isActive) a.setAttribute('aria-current', 'location');
        else a.removeAttribute('aria-current');
      });
    }

    function computeActiveIdFromScroll(): string {
      let activeId = headings[0]?.id ?? '';
      let closestDistance = Number.POSITIVE_INFINITY;

      for (const h of headings) {
        const distance = Math.abs(h.getBoundingClientRect().top - focusLineY);
        if (distance < closestDistance) {
          closestDistance = distance;
          activeId = h.id;
        }
      }

      return activeId;
    }

    function getHashTopicId(): string | null {
      const hashId = window.location.hash.replace(/^#/, '');
      if (!hashId) return null;
      return validTopicIds.has(hashId) ? hashId : null;
    }

    function lockToHash() {
      hashLockUntil = performance.now() + hashLockMs;
    }

    function isHashLocked() {
      return performance.now() < hashLockUntil;
    }

    function setActiveFromHash(lock = true) {
      const hashId = getHashTopicId();
      if (!hashId) return;
      if (lock) lockToHash();
      setActive(hashId);
    }

    function syncHashToActive(id: string) {
      const nextHash = `#${id}`;
      if (window.location.hash === nextHash) return;
      history.replaceState(null, '', nextHash);
    }

    // Initial sync: prefer URL hash when present.
    setActiveFromHash(false);
    if (!window.location.hash) {
      setActive(computeActiveIdFromScroll());
    }

    // Scroll listener (rAF-throttled) is more reliable than IntersectionObserver
    // alone, especially for short last sections that can't reach the threshold.
    let rafPending = false;
    function onScroll() {
      if (rafPending) return;
      rafPending = true;
      requestAnimationFrame(() => {
        if (isHashLocked()) {
          const hashId = getHashTopicId();
          if (hashId) {
            setActive(hashId);
            rafPending = false;
            return;
          }
        }

        const activeId = computeActiveIdFromScroll();
        setActive(activeId);
        syncHashToActive(activeId);
        rafPending = false;
      });
    }

    sidebarLinks.forEach((link) => link.addEventListener('click', () => lockToHash()));
    mobileLinks.forEach((link) => link.addEventListener('click', () => lockToHash()));

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    window.addEventListener('hashchange', () => setActiveFromHash());
  }

  setupFurtherMathsTopicNav();
</script>
)}
