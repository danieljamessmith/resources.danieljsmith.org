---
import BoardPills from '~/components/BoardPills.astro';
import {
  boardsToDataAttributeValue,
  getResourceBoards,
  type Resource,
} from '~/data/resources';

interface Props {
  pair: { questions: Resource; solutions: Resource };
}

const { pair } = Astro.props;
const boards = getResourceBoards(pair.questions);
const boardsAttr = boardsToDataAttributeValue(boards);
---

<div
  data-card-href={`/view/${pair.questions.id}`}
  data-boards={boardsAttr}
  class="exam-board-card cursor-pointer flex items-center justify-between gap-3 px-3 py-2.5 rounded-lg bg-slate-800/60 border border-slate-700/60 hover:bg-slate-800/80 hover:border-indigo-500/30 transition-colors transition-opacity duration-200 opacity-100"
>
  <div class="min-w-0">
    <p class="text-sm font-medium text-slate-100 truncate">{pair.questions.title}</p>
    <p class="text-xs text-slate-400 mt-0.5 leading-none flex flex-wrap items-center gap-x-1">
      <span>
        {pair.questions.questionCount} questions<span class="hidden sm:inline">{pair.questions.note ? ` · ${pair.questions.note}` : ''}</span>
      </span>
      <BoardPills boards={boards} />
    </p>
  </div>
  <div class="flex items-center gap-1 sm:gap-1.5 flex-shrink-0 pl-1">
    <a
      href={`/view/${pair.questions.id}`}
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center gap-1.5 px-2 py-1 sm:px-2.5 rounded-md text-xs font-medium text-sky-300 bg-sky-500/5 hover:bg-sky-500/15 hover:text-sky-200 transition-colors"
      aria-label="Open questions in a new tab"
    >
      <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
      </svg>
      <span class="hidden sm:inline">Questions</span>
    </a>
    <a
      href={`/view/${pair.solutions.id}`}
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center gap-1.5 px-2 py-1 sm:px-2.5 rounded-md text-xs font-medium text-emerald-300 bg-emerald-500/5 hover:bg-emerald-500/15 hover:text-emerald-200 transition-colors"
      aria-label="Open solutions in a new tab"
    >
      <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
      </svg>
      <span class="hidden sm:inline">Solutions</span>
    </a>
  </div>
</div>
