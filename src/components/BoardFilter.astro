---
import { EXAM_BOARDS } from '~/data/resources';

interface Props {
  variant?: 'sidebar' | 'mobile';
}

const { variant = 'sidebar' } = Astro.props;

const filterItems = [
  { id: 'all' as const, label: 'All' },
  ...EXAM_BOARDS.map((b) => ({ id: b.id, label: b.label })),
];

const linkInactive =
  'block w-full text-left border-l-2 border-transparent pl-4 py-2 text-sm text-slate-400 hover:border-slate-400 hover:text-white transition-colors duration-150';
const mobileInactive =
  'flex-shrink-0 whitespace-nowrap rounded-full border border-slate-600/80 px-3 py-1.5 text-xs font-medium text-slate-300 transition-colors hover:border-purple-500/50 hover:text-white';
---

{
  variant === 'sidebar' ? (
    <nav
      class="board-filter-sidebar hidden w-full shrink-0 lg:block"
      aria-label="Exam board filter"
      data-board-filter-nav="sidebar"
    >
      <p class="mb-4 text-xs font-semibold uppercase tracking-widest text-slate-400">Exam Board</p>
      <ul class="space-y-1" role="list">
        {filterItems.map((item) => (
          <li>
            <button
              type="button"
              class={linkInactive}
              data-board-filter={item.id}
              data-board-filter-link="sidebar"
            >
              {item.label}
            </button>
          </li>
        ))}
      </ul>
    </nav>
  ) : (
    <nav
      class="board-filter-mobile -mx-1 mb-4 flex gap-2 overflow-x-auto pb-1 pt-1 lg:hidden"
      aria-label="Exam board filter"
      data-board-filter-nav="mobile"
    >
      {filterItems.map((item) => (
        <button
          type="button"
          class={mobileInactive}
          data-board-filter={item.id}
          data-board-filter-link="mobile"
        >
          {item.label}
        </button>
      ))}
    </nav>
  )
}
