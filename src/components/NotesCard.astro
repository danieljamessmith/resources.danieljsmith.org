---
import BoardPills from '~/components/BoardPills.astro';
import {
  boardsToDataAttributeValue,
  getResourceBoards,
  type Resource,
} from '~/data/resources';

interface Props {
  note: Resource;
}

const { note } = Astro.props;
const boards = getResourceBoards(note);
const boardsAttr = boardsToDataAttributeValue(boards);
---

<div
  data-card-href={`/view/${note.id}`}
  data-boards={boardsAttr}
  class="exam-board-card cursor-pointer flex items-center justify-between gap-3 px-3 py-2.5 rounded-lg bg-slate-800/60 border border-slate-700/60 border-l-2 border-l-violet-500/50 hover:bg-slate-800/80 hover:border-slate-600/70 hover:border-l-violet-500/70 transition-colors transition-opacity duration-200 opacity-100"
>
  <div class="min-w-0">
    <div class="flex items-center gap-2 min-w-0">
      <p class="text-sm font-medium text-slate-100 truncate">{note.title}</p>
      <span class="inline-flex items-center text-[10px] uppercase tracking-widest text-violet-300 bg-violet-500/10 border border-violet-500/30 rounded px-1 leading-4 flex-shrink-0">
        Notes
      </span>
    </div>
    <p class="text-xs text-slate-400 mt-0.5 leading-none truncate flex flex-wrap items-center gap-x-1">
      <span>{note.description}</span>
      <BoardPills boards={boards} />
    </p>
  </div>
  <div class="flex-shrink-0 pl-1">
    <a
      href={`/view/${note.id}`}
      class="flex items-center gap-1.5 px-2 py-1 sm:px-2.5 rounded-md text-xs font-medium text-violet-300 bg-violet-500/5 hover:bg-violet-500/15 hover:text-violet-200 transition-colors"
      aria-label="Open notes"
    >
      <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
      </svg>
      <span class="hidden sm:inline">View</span>
    </a>
  </div>
</div>
