                  >
                    <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                    </svg>
                    <span class="hidden sm:inline">Questions</span>
                  </a>
                  <a
                    href={`/view/${pair.solutions.id}`}
                    class="flex items-center gap-1.5 px-2 py-1 sm:px-2.5 rounded-md text-xs font-medium bg-emerald-950/70 text-emerald-300 border border-emerald-800/50 hover:bg-emerald-900/70 hover:text-emerald-200 transition-colors"
                  >
                    <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    <span class="hidden sm:inline">Solutions</span>
                  </a>
                </div>
              </div>
            ))}
          </div>

          <!-- ── Polar Coordinates ─────────────────────────────────────── -->
          <h2
            id="polar-coordinates"
            class="scroll-mt-24 text-lg font-semibold text-white mt-5 mb-3 flex items-center gap-3"
          >
            <span class="w-8 h-0.5 bg-slate-500 rounded-full" />
            Polar Coordinates
          </h2>

          <div class="mb-6 space-y-1.5">
            {polarPairs.map((pair) => (
              <div
                data-card-href={`/view/${pair.questions.id}`}
                class="cursor-pointer flex items-center justify-between gap-3 px-3 py-2.5 rounded-lg bg-slate-800/60 border border-slate-700/60 hover:bg-slate-800/80 hover:border-slate-600/70 transition-colors duration-150"
              >
                <div class="min-w-0">
                  <p class="text-sm font-medium text-slate-100 truncate">{pair.questions.title}</p>
