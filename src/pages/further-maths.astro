            <a
              href={`/view/${note.id}`}
              class="group block px-2 py-1.5 bg-purple-950/40 rounded-xl border border-purple-800/40 hover:border-purple-500/50 hover:shadow-lg hover:shadow-purple-500/5 hover:-translate-y-0.5 transition-all duration-200 min-w-0"
            >
              <p class="text-xs font-medium text-purple-400 uppercase tracking-wider leading-none">Notes</p>
              <div class="mt-0.5 flex items-start gap-2">
                <div class="flex-shrink-0 w-7 h-7 rounded-md bg-purple-500/10 flex items-center justify-center text-purple-400">
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="1.5"
                      d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
                    />
                  </svg>
                </div>
                <div class="min-w-0">
                  <h3 class="text-sm text-white font-medium leading-snug group-hover:text-purple-300 transition-colors">{note.title}</h3>
                  <p class="text-xs text-slate-400 leading-snug mt-0">{note.description}</p>
                </div>
              </div>
            </a>
          ))}
