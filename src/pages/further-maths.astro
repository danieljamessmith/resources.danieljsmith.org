---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import TopicNav from '~/components/TopicNav.astro';
import {
  getResourceDisplayDescription,
  getResourcePairs,
  getResourcesByTopic,
  type Resource,
} from '~/data/resources';

const FM = 'A-level Further Maths';

const furtherCalculusNotes = getResourcesByTopic(FM, 'Further Calculus').filter((r) => r.type === 'notes');

const rawFurtherCalculusPairs = getResourcePairs(FM, 'Further Calculus');
const furtherCalculusPairs = rawFurtherCalculusPairs.filter(
  (p): p is { questions: Resource; solutions: Resource } => p.solutions !== undefined,
);

const rawPairs = getResourcePairs(FM, 'Differential Equations');
const pairs = rawPairs.filter(
  (p): p is { questions: Resource; solutions: Resource } => p.solutions !== undefined,
);

const rawPolarPairs = getResourcePairs(FM, 'Polar Coordinates');
const polarPairs = rawPolarPairs.filter(
  (p): p is { questions: Resource; solutions: Resource } => p.solutions !== undefined,
);

const rawComplexPairs = getResourcePairs(FM, 'Complex Numbers');
const complexPairs = rawComplexPairs.filter(
  (p): p is { questions: Resource; solutions: Resource } => p.solutions !== undefined,
);

const vectorsNotes = getResourcesByTopic(FM, 'Vectors').filter((r) => r.type === 'notes');

const rawVectorPairs = getResourcePairs(FM, 'Vectors');
const vectorPairs = rawVectorPairs.filter(
  (p): p is { questions: Resource; solutions: Resource } => p.solutions !== undefined,
);
---

<Layout
  title="A-level Further Maths Questions by Topic | resources.danieljsmith.org"
  description="Free A-level Further Maths questions by topic with full worked solutions. Topics cover core content found across Edexcel, AQA, OCR A and OCR MEI specifications."
>
  <div class="min-h-screen flex flex-col">
    <Header showBack={true} />
    <main class="flex-1 w-full max-w-7xl mx-auto px-4 py-12 lg:px-6">
      <div class="lg:grid lg:grid-cols-[220px_minmax(0,1fr)] lg:gap-10 xl:gap-12">
        <TopicNav variant="sidebar" />
        <div class="min-w-0">
          <h1 class="text-2xl font-bold text-white">A-level Further Maths Questions by Topic</h1>
          <p class="text-slate-300 mt-2">
            Free exam-style question booklets with full worked solutions, organised by topic.
          </p>

          <TopicNav variant="mobile" />

          <h2
            id="further-calculus"
            class="scroll-mt-24 text-lg font-semibold text-white mt-5 mb-3 flex items-center gap-3"
          >
            <span class="w-8 h-0.5 bg-slate-500 rounded-full" />
            Further Calculus
          </h2>

      <div class="mb-6 space-y-1.5">
        <div class="grid sm:grid-cols-2 gap-x-2 gap-y-1.5">
