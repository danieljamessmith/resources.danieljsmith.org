                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </main>
    <Footer />
  </div>
</Layout>

<script>
  document.querySelectorAll<HTMLElement>('[data-card-href]').forEach((card) => {
    card.addEventListener('click', (e) => {
      // Let clicks on child <a> elements navigate naturally
      if ((e.target as Element).closest('a')) return;
      window.location.href = card.dataset.cardHref!;
    });
  });
</script>
