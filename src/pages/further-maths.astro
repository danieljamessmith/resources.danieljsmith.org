---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import TopicNav from '~/components/TopicNav.astro';
import { getResourcePairs, getResourcesByTopic, type Resource } from '~/data/resources';

const FM = 'A-level Further Maths';

const furtherCalculusNotes = getResourcesByTopic(FM, 'Further Calculus').filter((r) => r.type === 'notes');
const rawFurtherCalculusPairs = getResourcePairs(FM, 'Further Calculus');
const furtherCalculusPairs = rawFurtherCalculusPairs.filter(
  (p): p is { questions: Resource; solutions: Resource } => p.solutions !== undefined,
);

const rawPairs = getResourcePairs(FM, 'Differential Equations');
const pairs = rawPairs.filter(
  (p): p is { questions: Resource; solutions: Resource } => p.solutions !== undefined,
);

const rawPolarPairs = getResourcePairs(FM, 'Polar Coordinates');
const polarPairs = rawPolarPairs.filter(
  (p): p is { questions: Resource; solutions: Resource } => p.solutions !== undefined,
);

const rawComplexPairs = getResourcePairs(FM, 'Complex Numbers');
const complexPairs = rawComplexPairs.filter(
  (p): p is { questions: Resource; solutions: Resource } => p.solutions !== undefined,
);

const vectorsNotes = getResourcesByTopic(FM, 'Vectors').filter((r) => r.type === 'notes');
const rawVectorPairs = getResourcePairs(FM, 'Vectors');
const vectorPairs = rawVectorPairs.filter(
  (p): p is { questions: Resource; solutions: Resource } => p.solutions !== undefined,
);
---

<Layout
  title="A-level Further Maths Questions by Topic | resources.danieljsmith.org"
  description="Free A-level Further Maths questions by topic with full worked solutions. Topics cover core content found across Edexcel, AQA, OCR A and OCR MEI specifications."
>
  <div class="min-h-screen flex flex-col">
    <Header showBack={true} />
    <main class="flex-1 w-full max-w-7xl mx-auto px-4 py-12 lg:px-6">
      <div class="lg:grid lg:grid-cols-[220px_minmax(0,1fr)] lg:gap-10 xl:gap-12">
        <TopicNav variant="sidebar" />
        <div class="min-w-0">
          <h1 class="text-2xl font-bold text-white">A-level Further Maths Questions by Topic</h1>
          <p class="text-slate-300 mt-2">
            Free exam-style question booklets with full worked solutions, organised by topic.
          </p>

          <TopicNav variant="mobile" />

          <!-- ── Further Calculus ───────────────────────────────────────── -->
          <h2
            id="further-calculus"
            class="scroll-mt-24 text-lg font-semibold text-white mt-5 mb-3 flex items-center gap-3"
          >
            <span class="w-8 h-0.5 bg-slate-500 rounded-full" />
            Further Calculus
          </h2>

          <div class="mb-6 space-y-1.5">
            {furtherCalculusNotes.map((note) => (
              <div
                data-card-href={`/view/${note.id}`}
                class="cursor-pointer flex items-center justify-between gap-3 px-3 py-2.5 rounded-lg bg-slate-800/60 border border-slate-700/60 hover:bg-slate-800/80 hover:border-slate-600/70 transition-colors duration-150"
              >
                <div class="min-w-0">
                  <div class="flex items-center gap-2 min-w-0">
                    <p class="text-sm font-medium text-slate-100 truncate">{note.title}</p>
                    <span class="inline-flex items-center text-[10px] uppercase tracking-widest text-slate-500 border border-slate-600/80 rounded px-1 leading-4 flex-shrink-0">Notes</span>
                  </div>
                  <p class="text-xs text-slate-400 mt-0.5 leading-none truncate">{note.description}</p>
                </div>
                <div class="flex-shrink-0 pl-1">
                  <a
                    href={`/view/${note.id}`}
                    class="flex items-center gap-1.5 px-2 py-1 sm:px-2.5 rounded-md text-xs font-medium bg-violet-950/70 text-violet-300 border border-violet-800/50 hover:bg-violet-900/70 hover:text-violet-200 transition-colors"
                  >
                    <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                    </svg>
                    <span class="hidden sm:inline">View</span>
                  </a>
                </div>
              </div>
            ))}

            {furtherCalculusPairs.map((pair) => (
              <div
                data-card-href={`/view/${pair.questions.id}`}
                class="cursor-pointer flex items-center justify-between gap-3 px-3 py-2.5 rounded-lg bg-slate-800/60 border border-slate-700/60 hover:bg-slate-800/80 hover:border-slate-600/70 transition-colors duration-150"
              >
                <div class="min-w-0">
                  <p class="text-sm font-medium text-slate-100 truncate">{pair.questions.title}</p>
                  <p class="text-xs text-slate-400 mt-0.5 leading-none">
                    {pair.questions.questionCount} questions<span class="hidden sm:inline">{pair.questions.note ? ` · ${pair.questions.note}` : ''}</span>
                  </p>
                </div>
                <div class="flex items-center gap-1.5 sm:gap-2 flex-shrink-0 pl-1">
                  <a
                    href={`/view/${pair.questions.id}`}
                    class="flex items-center gap-1.5 px-2 py-1 sm:px-2.5 rounded-md text-xs font-medium bg-sky-950/70 text-sky-300 border border-sky-800/50 hover:bg-sky-900/70 hover:text-sky-200 transition-colors"
                  >
                    <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                    </svg>
                    <span class="hidden sm:inline">Questions</span>
                  </a>
                  <a
                    href={`/view/${pair.solutions.id}`}
                    class="flex items-center gap-1.5 px-2 py-1 sm:px-2.5 rounded-md text-xs font-medium bg-emerald-950/70 text-emerald-300 border border-emerald-800/50 hover:bg-emerald-900/70 hover:text-emerald-200 transition-colors"
                  >
                    <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    <span class="hidden sm:inline">Solutions</span>
                  </a>
                </div>
              </div>
            ))}
          </div>

          <!-- ── Differential Equations ────────────────────────────────── -->
          <h2
            id="differential-equations"
            class="scroll-mt-24 text-lg font-semibold text-white mt-5 mb-3 flex items-center gap-3"
          >
            <span class="w-8 h-0.5 bg-slate-500 rounded-full" />
