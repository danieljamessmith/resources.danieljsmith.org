---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import {
  getFurtherMathsQuestionTotalRoundedDownTen,
  getFurtherMathsTotalQuestionCount,
  getResourcesByCategory,
} from '~/data/resources';

const tmuaCount = getResourcesByCategory('TMUA').length;
const fmQuestionTotal = getFurtherMathsTotalQuestionCount();
const fmOverQuestions = getFurtherMathsQuestionTotalRoundedDownTen();
const fmQuestionsLine =
  fmOverQuestions >= 10
    ? `Over ${fmOverQuestions} custom exam questions with worked solutions`
    : fmQuestionTotal > 0
      ? `${fmQuestionTotal} custom exam questions with worked solutions`
      : 'Question-by-topic booklets with worked solutions';
---

<Layout
  title="Free Maths Resources — Practice Papers & Questions by Topic"
  description="Free A-level Further Maths topic booklets and TMUA practice papers with worked solutions."
>
  <div class="min-h-screen flex flex-col">
    <Header />
    <div class="flex-1 flex flex-col">
      <section class="text-center max-w-2xl mx-auto px-4 py-16 md:py-24">
        <h1 class="text-4xl md:text-5xl font-bold text-white">Free Maths Resources</h1>
        <p class="text-lg text-slate-300 mt-4">
          Practice papers, question-by-topic booklets, and worked solutions.
        </p>
      </section>

      <section class="max-w-4xl mx-auto px-4 pb-20 w-full">
        <h2 class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-6">Choose your subject</h2>
        <div class="grid sm:grid-cols-2 gap-6">
          <a
            href="/further-maths"
            class="group block p-6 bg-surface-raised rounded-2xl border border-slate-700/50 hover:border-blue-500/50 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-blue-500/5 transition-all duration-200"
          >
            <div class="w-12 h-12 rounded-xl bg-indigo-500/10 flex items-center justify-center text-indigo-400">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"
                />
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-white mt-4">A-level Further Maths</h3>
            <p class="text-slate-300 mt-2 text-sm">
              Question-by-topic booklets with worked solutions for A-level Further Maths
            </p>
            <p class="text-xs text-slate-400 mt-4">{fmQuestionsLine}</p>
            <div class="mt-4 flex items-center text-blue-400 text-sm font-medium">
              <span>Open</span>
              <svg
                class="w-4 h-4 ml-1 transition-transform group-hover:translate-x-1"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          </a>

          <a
            href="/tmua"
            class="group block p-6 bg-surface-raised rounded-2xl border border-slate-700/50 hover:border-blue-500/50 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-blue-500/5 transition-all duration-200"
          >
            <div class="w-12 h-12 rounded-xl bg-blue-500/10 flex items-center justify-center text-blue-400">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="1.5"
                  d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"
                />
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-white mt-4">TMUA</h3>
            <p class="text-slate-300 mt-2 text-sm">
              Custom Practice Papers for the TMUA
            </p>
            <p class="text-xs text-slate-400 mt-4">{tmuaCount} resources available</p>
            <div class="mt-4 flex items-center text-blue-400 text-sm font-medium">
              <span>Open</span>
              <svg
                class="w-4 h-4 ml-1 transition-transform group-hover:translate-x-1"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                aria-hidden="true"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          </a>
        </div>
      </section>
    </div>
    <Footer />
  </div>
</Layout>
