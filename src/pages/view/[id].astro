---
import Layout from '~/layouts/Layout.astro';
import { resources, getResourceById, getResourceDisplayDescription } from '~/data/resources';

export function getStaticPaths() {
  return resources.map((resource) => ({
    params: { id: resource.id },
  }));
}

const { id } = Astro.params;
const resource = getResourceById(id);

if (!resource) {
  return Astro.redirect('/404');
}

type BreadcrumbNav =
  | { mode: 'single'; href: string; label: string; aria: string }
  | {
      mode: 'fm';
      parentHref: string;
      parentLabel: string;
      sectionHref: string;
      sectionLabel: string;
    };

const categoryBreadcrumb: Record<string, BreadcrumbNav> = {
  TMUA: { mode: 'single', href: '/tmua', label: 'TMUA', aria: 'Back to TMUA resources' },
  'FM - Core Pure': {
    mode: 'fm',
    parentLabel: 'Further Maths',
    parentHref: '/further-maths',
    sectionLabel: 'Core Pure',
    sectionHref: '/further-maths/core-pure',
  },
  'FM - Further Mechanics': {
    mode: 'fm',
    parentLabel: 'Further Maths',
    parentHref: '/further-maths',
    sectionLabel: 'Further Mechanics',
    sectionHref: '/further-maths/further-mechanics',
  },
};
const breadcrumb = categoryBreadcrumb[resource.category] ?? {
  mode: 'single' as const,
  href: '/',
  label: 'Home',
  aria: 'All resources',
};
const displayDescription = getResourceDisplayDescription(resource);

const paired =
  resource.pairId &&
  (resource.type === 'questions' || resource.type === 'solutions') &&
  getResourceById(resource.pairId)
    ? {
        href: `/view/${resource.pairId}` as const,
        label: resource.type === 'questions' ? '-> Solutions' : '<- Questions',
        aria:
          resource.type === 'questions'
            ? 'Open solutions for this question sheet'
            : 'Back to the questions sheet',
        /** Emerald = solutions; blue matches Further Maths “Questions” cards on section pages. */
        buttonClass:
          resource.type === 'questions'
            ? 'border-emerald-500/55 text-emerald-100 hover:bg-emerald-950/45 hover:border-emerald-400/70'
            : 'border-blue-800/45 text-blue-300 hover:bg-blue-950/40 hover:border-blue-500/50',
      }
    : null;
/*
  PDF open param #view=FitH: Firefox fits width as intended. Chromium (Chrome/Edge PDFium)
  over-zooms inside iframes. Plain URL + full-width iframe keeps Chromium readable; we only
  append FitH on Firefox. A PDF.js embed would avoid UA branching but is heavier.
*/
---

<Layout title={`${resource.title} | resources.danieljsmith.org`} description={displayDescription}>
  <div class="min-h-screen flex flex-col">
    <header class="bg-surface/80 backdrop-blur-md border-b border-slate-700/50 sticky top-0 z-10">
      <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between gap-4">
        <div class="flex items-center gap-2 min-w-0 flex-1">
          {/*
            Single-row breadcrumb chain ending with the sheet title; the title is the final,
            emphasised segment. This keeps the viewer top-bar to one row (previously three:
            breadcrumb, title, description), saving vertical space on small screens.
          */}
          <nav
            class="flex items-center gap-2 text-sm min-w-0 flex-1"
            aria-label="Breadcrumb"
          >
            {breadcrumb.mode === 'single' ? (
              <>
                <a
                  href={breadcrumb.href}
                  class="inline-flex items-center gap-1.5 flex-shrink-0 p-1 -ml-1 rounded-lg text-slate-400 hover:text-blue-400 hover:bg-surface-overlay transition-colors"
                  aria-label={breadcrumb.aria}
                  title={breadcrumb.aria}
                >
                  <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                  </svg>
                  {/* Section label next to the arrow on mobile only; md+ shows it inside the breadcrumb chain below. */}
                  <span class="md:hidden text-slate-300 text-sm font-medium">{breadcrumb.label}</span>
                </a>
                <a
                  href={breadcrumb.href}
                  class="hidden md:inline text-slate-300 hover:text-blue-400 transition-colors flex-shrink-0"
                >
                  {breadcrumb.label}
                </a>
                <span class="hidden md:inline text-slate-500 flex-shrink-0" aria-hidden="true">/</span>
              </>
            ) : (
              <>
                <a
                  href={breadcrumb.sectionHref}
                  class="inline-flex items-center gap-1.5 flex-shrink-0 p-1 -ml-1 rounded-lg text-slate-400 hover:text-blue-400 hover:bg-surface-overlay transition-colors"
                  aria-label={`Back to ${breadcrumb.sectionLabel}`}
                  title={`Back to ${breadcrumb.sectionLabel}`}
                >
                  <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                  </svg>
                  {/* Section label next to the arrow on mobile only; md+ shows it inside the breadcrumb chain below. */}
                  <span class="md:hidden text-slate-300 text-sm font-medium">{breadcrumb.sectionLabel}</span>
                </a>
                <a
                  href={breadcrumb.parentHref}
                  class="hidden md:inline text-slate-300 hover:text-blue-400 transition-colors flex-shrink-0"
                >
                  {breadcrumb.parentLabel}
                </a>
                <span class="hidden md:inline text-slate-500 flex-shrink-0" aria-hidden="true">/</span>
                <a
                  href={breadcrumb.sectionHref}
                  class="hidden md:inline text-slate-300 hover:text-blue-400 transition-colors flex-shrink-0"
                >
                  {breadcrumb.sectionLabel}
                </a>
                <span class="hidden md:inline text-slate-500 flex-shrink-0" aria-hidden="true">/</span>
              </>
            )}
            {/* Title is shown only at md+; on mobile the "Open PDF" landing already renders a large title + description. */}
            <h1 class="hidden md:block text-base font-semibold text-white truncate min-w-0" title={displayDescription}>
              {resource.title}
            </h1>
          </nav>
        </div>
        <div class="flex flex-shrink-0 items-center gap-2">
          {paired && (
            <a
              href={paired.href}
              target="_blank"
              rel="noopener noreferrer"
              class:list={[
                'inline-flex items-center gap-1.5 px-3 sm:px-4 py-2 rounded-lg border text-sm font-medium transition-colors whitespace-nowrap',
                paired.buttonClass,
              ]}
              aria-label={paired.aria}
            >
              {paired.label}
            </a>
          )}
          <a
            href={resource.file}
            download={resource.downloadName}
            class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium transition-colors"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
            <span class="hidden sm:inline">Download</span>
          </a>
          <a
            href={resource.file}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Open PDF in new tab"
            class="inline-flex items-center gap-2 px-3 sm:px-4 py-2 rounded-lg border border-slate-600 text-slate-200 hover:bg-slate-800/80 text-sm font-medium transition-colors"
          >
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
            <span class="hidden sm:inline">Open in new tab</span>
          </a>
        </div>
      </div>
    </header>

    <main class="flex-1 flex flex-col min-h-0">
      <div class="hidden md:flex flex-1 bg-surface-raised flex-col min-h-0">
        <iframe
          id="pdf-embed"
          src={resource.file}
          class="w-full flex-1 min-h-[calc(100vh-64px)] border-0"
          title={resource.title}
        />
        <script is:inline define:vars={{ pdfPath: resource.file }}>
          (function () {
            var el = document.getElementById('pdf-embed');
            if (!el || !/Firefox\//.test(navigator.userAgent)) return;
            el.src = pdfPath + '#view=FitH';
          })();
        </script>
      </div>

      <div class="flex md:hidden flex-1 items-center justify-center px-6 py-12">
        <div class="w-full max-w-sm text-center space-y-6">
          <div>
            <h2 class="text-xl font-semibold text-white">{resource.title}</h2>
            <p class="text-sm text-slate-400 mt-1">{displayDescription}</p>
          </div>

          <a
            href={resource.file}
            target="_blank"
            rel="noopener noreferrer"
            class="block w-full py-3 rounded-lg bg-blue-600 hover:bg-blue-500 text-white text-base font-semibold transition-colors"
          >
            Open PDF
          </a>

          <div class="flex gap-3">
            <a
              href={resource.file}
              download={resource.downloadName}
              class="flex-1 py-2.5 rounded-lg border border-slate-600 text-slate-200 hover:bg-slate-800/80 text-sm font-medium transition-colors text-center"
            >
              Download
            </a>

            {paired && (
              <a
                href={paired.href}
                target="_blank"
                rel="noopener noreferrer"
                class:list={[
                  'flex-1 py-2.5 rounded-lg border text-sm font-medium transition-colors text-center',
                  paired.buttonClass,
                ]}
              >
                {paired.label}
              </a>
            )}
          </div>
        </div>
      </div>
    </main>
  </div>
</Layout>
