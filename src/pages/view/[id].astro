---
import Layout from '~/layouts/Layout.astro';
import { resources, getResourceById } from '~/data/resources';

export function getStaticPaths() {
  return resources.map((resource) => ({
    params: { id: resource.id },
  }));
}

const { id } = Astro.params;
const resource = getResourceById(id);

if (!resource) {
  return Astro.redirect('/404');
}

const categoryBack: Record<string, { href: string; aria: string }> = {
  TMUA: { href: '/tmua', aria: 'Back to TMUA resources' },
  'A-level Further Maths': { href: '/further-maths', aria: 'Back to Further Maths resources' },
};
const back = categoryBack[resource.category] ?? { href: '/', aria: 'All resources' };
---

<Layout title={`${resource.title} | resources.danieljsmith.org`} description={resource.description}>
  <div class="min-h-screen flex flex-col">
    <header class="bg-surface/80 backdrop-blur-md border-b border-slate-700/50 sticky top-0 z-10">
      <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between gap-4">
        <div class="flex items-center gap-4 min-w-0">
          <a
            href={back.href}
            class="text-slate-400 hover:text-blue-400 transition-colors flex-shrink-0 p-1 -ml-1 rounded-lg hover:bg-surface-overlay"
            aria-label={back.aria}
            title={back.aria}
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
          </a>
          <div class="min-w-0">
            <h1 class="text-lg font-semibold text-white truncate">{resource.title}</h1>
            <p class="text-xs text-slate-400 truncate">{resource.description}</p>
          </div>
        </div>
        <div class="flex flex-shrink-0 items-center gap-2">
          <a
            href={resource.file}
            download
            class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-500 text-white text-sm font-medium transition-colors"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
            <span class="hidden sm:inline">Download</span>
          </a>
          <a
            href={resource.file}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Open PDF in new tab"
            class="inline-flex items-center gap-2 px-3 sm:px-4 py-2 rounded-lg border border-slate-600 text-slate-200 hover:bg-slate-800/80 text-sm font-medium transition-colors"
          >
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
            <span class="hidden sm:inline">Open in new tab</span>
          </a>
        </div>
      </div>
    </header>

    <main class="flex-1 flex flex-col min-h-0">
      <div class="flex-1 bg-surface-raised flex flex-col min-h-0">
        <div class="max-w-7xl mx-auto w-full flex-1 flex flex-col min-h-[calc(100vh-120px)]">
          <iframe
            src={resource.file}
            class="w-full flex-1 min-h-[calc(100vh-120px)]"
            title={resource.title}
          />
        </div>
      </div>
    </main>
  </div>
</Layout>
