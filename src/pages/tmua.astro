---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import { getResourcesByCategory } from '~/data/resources';

const tmuaResources = getResourcesByCategory('TMUA');
---

<Layout title="TMUA Resources | resources.danieljsmith.org">
  <div class="min-h-screen flex flex-col">
    <Header showBack={true} />
    <main class="flex-1 max-w-6xl mx-auto px-4 py-12 w-full">
      <h1 class="text-2xl font-bold text-white">TMUA Resources</h1>
      <p class="text-slate-300 mt-2">
        Practice papers for the Test of Mathematics for University Admission
      </p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mt-8">
        {tmuaResources.map((resource) => (
          <a
            href={`/view/${resource.id}`}
            class="group block p-5 bg-surface-raised rounded-xl border border-slate-700/50 hover:border-blue-500/50 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-blue-500/5 transition-all duration-200"
          >
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-blue-500/10 flex items-center justify-center text-blue-400">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.5"
                    d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"
                  />
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <h2 class="text-white font-medium group-hover:text-blue-400 transition-colors">{resource.title}</h2>
                <p class="text-sm text-slate-400 mt-1">{resource.description}</p>
              </div>
            </div>
          </a>
        ))}
      </div>
    </main>
    <Footer />
  </div>
</Layout>
